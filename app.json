{
  "expo": {
    "name": "SkinJournal",
    "slug": "skinjournal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "skinjournal",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skinjournal.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SkinJournal uses the camera for daily progress photos.",
        "NSPhotoLibraryUsageDescription": "SkinJournal saves and exports your journey photos.",
        "NSPhotoLibraryAddUsageDescription": "SkinJournal saves share cards to your photo library.",
        "NSLocationWhenInUseUsageDescription": "SkinJournal uses your approximate location once to personalize content (you can decline)."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FAF7F8"
      },
      "package": "com.skinjournal.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SkinJournal to take daily progress photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SkinJournal uses your approximate location once to personalize content (you can decline)."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#F2A8BC"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
