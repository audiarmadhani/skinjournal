EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Face analysis uses OpenAI via Supabase Edge Function (server-side only).
# Set the secret on your Supabase project — do NOT put the key in the app:
#   supabase secrets set OPENAI_API_KEY=sk-...
# Then deploy: supabase functions deploy analyze-face
#
# EXPO_PUBLIC_OPENAI_API_KEY is no longer used for face analysis (deprecated).

EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=
EXPO_PUBLIC_USE_MOCK=true
# Set true to unlock face analysis UI for all users (local testing; Edge Function still checks Premium in DB)
EXPO_PUBLIC_FORCE_PREMIUM=false
